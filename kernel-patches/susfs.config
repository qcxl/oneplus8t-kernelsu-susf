# SUSFS configuration for OnePlus 8T (kebab)
# LineageOS 20 (Android 13) - Kernel 4.19

# SUSFS core features
CONFIG_KSU_SUSFS=y
CONFIG_KSU_SUSFS_HAS_MAGIC_MOUNT=y
CONFIG_KSU_SUSFS_SUS_PATH=y
CONFIG_KSU_SUSFS_SUS_MOUNT=y
CONFIG_KSU_SUSFS_AUTO_ADD_SUS_KSTAT=y
CONFIG_KSU_SUSFS_AUTO_ADD_SUS_MOUNT=y
CONFIG_KSU_SUSFS_HIDE_KSU_SUSFS_SYMBOLS=y

# Hide features
CONFIG_KSU_SUSFS_SUS_KSTAT=y
CONFIG_KSU_SUSFS_SUS_MOUNT=y
CONFIG_KSU_SUSFS_SUS_PROC=y
CONFIG_KSU_SUSFS_SUS_PATH=y

# Compatibility
CONFIG_KSU_SUSFS_OPEN_RESTRICTED_PROC=y
CONFIG_KSU_SUSFS_SUS_SU=y
